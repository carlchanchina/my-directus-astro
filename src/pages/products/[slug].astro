---
export const prerender = true;

import ProductDetailClient from '@/components/layout/ProductDetailClient';
import Layout from '@/layouts/BaseLayout.astro';
import { getProductBySlug, getAllProducts, relatedProducts } from '@/lib/products';
import type { Product } from '@/lib/products';

export async function getStaticPaths() {
  const products = getAllProducts();
  return products.map(product => ({
    params: { slug: product.slug },
  }));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : typeof slugParam === 'string' ? slugParam : '';

let product: Product | null = null;
try {
  product = getProductBySlug(slug as string) || null;
} catch (error) {
  console.error('Error loading product:', error);
  product = null;
}

if (!product) {
  return Astro.redirect('/404');
}

const related = relatedProducts(product.slug, 3);
const siteURL = import.meta.env.PUBLIC_SITE_URL || '';
const productUrl = `${siteURL}/products/${slug}`;

const metadata = {
  title: product.name,
  description: product.description,
  openGraph: {
    title: product.name,
    description: product.description,
    url: productUrl,
    type: 'product',
    images: product.image ? [{ url: product.image }] : undefined,
  },
};
---

<Layout metadata={metadata}>
  <ProductDetailClient
    client:load
    initialProduct={product}
    relatedProducts={related}
    productUrl={productUrl}
    slug={slug}
  />
</Layout>
