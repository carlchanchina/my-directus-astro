---
import BlogPostClient from '@/components/layout/BlogPostClient';
import Layout from '@/layouts/BaseLayout.astro';
import { getDirectusAssetURL } from '@/lib/directus/directus-utils';
import {
  fetchAuthorById,
  fetchPostByIdAndVersion,
  fetchPostBySlug,
  fetchRelatedPosts,
  getPostIdBySlug,
} from '@/lib/directus/fetchers';
import { translations, type Language } from '@/lib/i18n';
import type { DirectusUser, Post } from '@/types/directus-schema';

type Params = {
  lang?: string;
  slug?: string;
};

export async function getStaticPaths() {
  const posts = await fetchAllPostsForI18n();

  const paths = [];
  for (const lang of ['en', 'zh']) {
    for (const post of posts) {
      paths.push({
        params: { lang, slug: post.slug },
      });
    }
  }

  return paths;
}

// Helper function - you can modify this based on your Directus schema
async function fetchAllPostsForI18n() {
  try {
    // This assumes you have a way to fetch all posts
    // Adjust based on your actual implementation
    return [];
  } catch {
    return [];
  }
}

const { lang = 'en', slug = '' } = Astro.params;
const currentLang = lang as Language;

const query = Astro.url.searchParams;
const id = query.get('id') || '';
const rawVersion = query.get('version') || '';
const version = rawVersion !== 'main' ? rawVersion : '';
const preview = query.get('preview') === 'true';
const token = preview ? import.meta.env.DIRECTUS_SERVER_TOKEN || '' : '';

const isDraft = preview || (!!version && version !== 'published');

let post: Post | null = null;
try {
  let postId = id;
  if (version && !postId) {
    const foundPostId = await getPostIdBySlug(slug as string, token || undefined);
    postId = foundPostId || '';
  }

  if (postId && version) {
    const result = await fetchPostByIdAndVersion(postId, version, slug as string, token || undefined);
    post = result.post;
  } else {
    post = await fetchPostBySlug(slug as string, isDraft, token || undefined);
  }
} catch (error) {
  console.error('Error loading post:', error);
  post = null;
}

if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = await fetchRelatedPosts(post.id);
const author = post.author && typeof post.author === 'object' ? (post.author as DirectusUser) : null;
const authorName = [author?.first_name, author?.last_name].filter(Boolean).join(' ');
const siteURL = import.meta.env.PUBLIC_SITE_URL || '';
const postUrl = `${siteURL}/${lang}/blog/${slug}`;
const ogImage = post.image ? getDirectusAssetURL(post.image as string) : null;

const metadata = {
  title: post?.seo?.title ?? post.title ?? '',
  description: post?.seo?.meta_description ?? '',
  openGraph: {
    title: post?.seo?.title ?? post.title ?? '',
    description: post?.seo?.meta_description ?? '',
    url: postUrl,
    type: 'article',
    images: ogImage ? [{ url: ogImage }] : undefined,
  },
};

// Route caching (Astro v6): only cache published posts; never cache preview/draft
if (Astro.cache.enabled) {
  if (isDraft) {
    Astro.cache.set(false);
  } else {
    Astro.cache.set({
      maxAge: 300,
      swr: 60,
      tags: ['blog', `post:${post.id}`],
    });
  }
}
---

<Layout metadata={metadata}>
  <BlogPostClient
    client:load
    initialPost={post}
    relatedPosts={relatedPosts}
    author={author}
    authorName={authorName}
    postUrl={postUrl}
    slug={slug}
    lang={currentLang}
  />
</Layout>
