---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container';
import Headline from '@/components/ui/Headline';
import Tagline from '@/components/ui/Tagline';
import { Button } from '@/components/ui/button';
import { translations, type Language } from '@/lib/i18n';

type Params = {
  lang?: string;
};

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}

const { lang = 'en' } = Astro.params;
const currentLang = lang as Language;

const t = (key: string) => {
  const keys = key.split('.');
  let value: any = translations[currentLang];
  for (const k of keys) {
    value = value?.[k];
  }
  return value || key;
};

const metadata = {
  title: 'Home',
  description: 'Welcome to our website',
};
---

<Layout metadata={metadata}>
  <Container className="py-20 sm:py-32 lg:py-40">
    {/* Hero Section */}
    <div className="text-center mb-20">
      <Tagline>{t('nav.home')}</Tagline>
      <Headline level="h1" className="mb-6">
        {currentLang === 'zh' ? '欢迎来到我们的网站' : 'Welcome to Our Website'}
      </Headline>
      <p className="text-lg text-muted-foreground max-w-2xl mx-auto mb-8">
        {currentLang === 'zh' 
          ? '发现我们的高质量产品和文章，为您提供最好的体验。'
          : 'Discover our high-quality products and articles for the best experience.'}
      </p>

      <div className="flex gap-4 justify-center">
        <Button size="lg" asChild>
          <a href={`/${lang}/products`}>{t('nav.products')}</a>
        </Button>
        <Button size="lg" variant="outline" asChild>
          <a href={`/${lang}/blog`}>{t('nav.blog')}</a>
        </Button>
      </div>
    </div>

    {/* Features Grid */}
    <div className="grid grid-cols-1 md:grid-cols-3 gap-8 py-20 border-y">
      <div className="text-center">
        <div className="text-4xl mb-4">🛍️</div>
        <h3 className="text-lg font-semibold mb-2">{t('nav.products')}</h3>
        <p className="text-muted-foreground">
          {currentLang === 'zh' ? '浏览我们精选的产品系列' : 'Browse our curated product collection'}
        </p>
      </div>
      <div className="text-center">
        <div className="text-4xl mb-4">📝</div>
        <h3 className="text-lg font-semibold mb-2">{t('nav.blog')}</h3>
        <p className="text-muted-foreground">
          {currentLang === 'zh' ? '阅读最新的文章和见解' : 'Read the latest articles and insights'}
        </p>
      </div>
      <div className="text-center">
        <div className="text-4xl mb-4">🌍</div>
        <h3 className="text-lg font-semibold mb-2">{t('common.language')}</h3>
        <p className="text-muted-foreground">
          {currentLang === 'zh' ? '支持多种语言' : 'Multiple language support'}
        </p>
      </div>
    </div>
  </Container>
</Layout>
